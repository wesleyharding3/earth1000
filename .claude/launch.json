{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "earth",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path'),dir=process.cwd(),mime={'.html':'text/html','.js':'text/javascript','.css':'text/css','.json':'application/json','.png':'image/png','.jpg':'image/jpeg','.svg':'image/svg+xml','.ico':'image/x-icon'};http.createServer((q,r)=>{const f=path.join(dir,q.url==='/'?'index.html':q.url.split('?')[0]);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}const ext=path.extname(f);r.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream','Cache-Control':'no-cache'});r.end(d)})}).listen(process.env.PORT||3900,()=>console.log('OK'))"],
      "port": 3900,
      "autoPort": true
    },
    {
      "name": "earth-api",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-r", "dotenv/config", "server.js"],
      "env": {
        "PORT": "3999",
        "DEV_EDITOR_BYPASS": "1",
        "DOTENV_CONFIG_PATH": "/Users/wesleyharding3/Desktop/earth00/.env",
        "DOTENV_CONFIG_OVERRIDE": "true"
      },
      "port": 3999,
      "autoPort": false
    }
  ]
}
