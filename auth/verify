<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Verifying — Earth00</title>
  <style>
    html, body {
      margin: 0; padding: 0; height: 100%;
      background: #000; color: rgba(255, 220, 180, 0.65);
      font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      display: flex; align-items: center; justify-content: center;
      letter-spacing: 0.02em;
    }
    .stack { display: flex; flex-direction: column; align-items: center; gap: 14px; }
    .e {
      font-family: "Georgia", "Times New Roman", serif;
      font-style: italic; font-weight: 900; font-size: 56px; line-height: 1;
      color: rgba(255, 175, 50, 1);
      text-shadow: 0 0 20px rgba(255, 140, 30, 0.6), 0 0 50px rgba(255, 100, 20, 0.3);
      letter-spacing: -0.04em;
    }
    .label {
      font-size: 11px; font-weight: 800; letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255, 220, 180, 0.55);
    }
    noscript {
      max-width: 320px; text-align: center;
      color: rgba(255, 220, 180, 0.85);
      padding: 18px 22px; border: 1px solid rgba(255,255,255,0.12);
      border-radius: 12px; background: rgba(255,255,255,0.04);
    }
    noscript a { color: rgba(255, 175, 50, 1); }
  </style>
</head>
<body>
  <div class="stack">
    <div class="e">e</div>
    <div class="label">Verifying…</div>
  </div>
  <noscript>
    <p>JavaScript is required to complete sign-in. <a href="/">Open Earth00</a> and try the verification link again.</p>
  </noscript>
  <script>
    // Browsers that loaded this page mean the user clicked the email
    // verification link from a device WITHOUT the Earth00 iOS app
    // (Universal Links would have opened the app instead). Redirect to
    // the SPA at /, preserving query (?code=…) AND hash (#access_token=…)
    // so the auth listener inside index.html can complete the handoff.
    // location.replace avoids polluting browser history with the verify URL.
    (function () {
      var dest = '/' + (window.location.search || '') + (window.location.hash || '');
      try { window.location.replace(dest); }
      catch (_) { window.location.href = dest; }
    })();
  </script>
</body>
</html>
